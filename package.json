    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.17",
    "@types/dompurify": "^3.0.5",
    "@types/react-router-dom": "^5.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.2.7",
    "firebase": "^12.2.1",
    "lexical": "^0.35.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",

{
  "name": "reciperevamped-blog-service",
  "version": "1.0.0",
  "description": "Blog management service for RecipeRevamped - AI-powered recipe conversion platform",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "functions-framework --target=reciperevamped-blog-assets",
    "dev": "functions-framework --target=reciperevamped-blog-assets --port=8080",
    "test": "jest --coverage",
    "lint": "eslint . --ext .js,.json",
    "lint:fix": "eslint . --ext .js,.json --fix"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.3.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "@google-cloud/firestore": "^7.1.0",
    "@google-cloud/storage": "^7.7.0",
    "firebase-admin": "^12.0.0",
    "sharp": "^0.33.1",
    "rss": "^1.2.2",
    "marked": "^11.1.1",
    "isomorphic-dompurify": "^2.6.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reciperevamped/blog-service.git"
  },
  "keywords": [
    "blog",
    "cms",
    "api",
    "google-cloud",
    "firestore",
    "express",
    "reciperevamped",
    "food-tech",
    "ai-recipes"
  ],
  "author": {
    "name": "RecipeRevamped Team",
    "email": "tech@reciperevamped.com",
    "url": "https://reciperevamped.com"
  },
  "license": "MIT",
  "private": true,
  "gcp": {
    "service": "blog-service",
    "region": "us-central1",
    "memory": "1Gi",
    "cpu": "1",
    "minInstances": 0,
    "maxInstances": 10,
    "concurrency": 80,
    "timeout": "300s"
  },
  "environment": {
    "NODE_ENV": "production",
    "GOOGLE_CLOUD_PROJECT": "reciperevamped-428797186446",
    "STORAGE_BUCKET": "reciperevamped-blog-assets",
    "ADMIN_TOKEN": "REPLACE_WITH_SECURE_TOKEN",
    "CORS_ORIGINS": "https://reciperevamped.com,https://www.reciperevamped.com"
  },
  "healthcheck": {
    "path": "/health",
    "interval": "30s",
    "timeout": "10s",
    "retries": 3
  },
  "features": [
    "Blog post CRUD operations with Firestore storage",
    "Advanced search with full-text filtering",
    "Image optimization with Sharp and Google Cloud Storage",
    "SEO-friendly sitemap.xml generation",
    "RSS feed generation for content syndication",
    "Content management with markdown support and sanitization",
    "Analytics tracking for post views and engagement",
    "Rate limiting and security with Helmet.js",
    "Admin authentication for content operations",
    "Pagination and category filtering",
    "Related posts suggestions",
    "GDPR-compliant data handling"
  ],
  "api_endpoints": {
    "public": [
      "GET /health - Service health check",
      "GET /api/blog/posts - List blog posts with pagination",
      "GET /api/blog/posts/:slug - Get single blog post",
      "GET /api/blog/search - Search blog posts",
      "GET /api/blog/categories - List blog categories",
      "GET /api/blog/rss - RSS feed generation",
      "GET /api/blog/sitemap - XML sitemap generation"
    ],
    "admin_only": [
      "POST /api/blog/posts - Create new blog post",
      "PUT /api/blog/posts/:id - Update blog post",
      "DELETE /api/blog/posts/:id - Delete blog post",
      "POST /api/blog/upload - Upload and optimize images",
      "GET /api/blog/analytics - View blog analytics"
    ]
  },
  "deployment": {
    "platform": "Google Cloud Run",
    "build_command": "npm install --production",
    "start_command": "npm start",
    "port": 8080,
    "memory_limit": "1Gi",
    "cpu_allocation": "1 vCPU",
    "request_timeout": "300s",
    "max_concurrent_requests": 80
  },
  "security": {
    "features": [
      "Rate limiting (100 requests/15min, 10 content ops/hour)",
      "CORS protection with whitelist",
      "Content Security Policy headers",
      "Input validation and sanitization",
      "DOMPurify for HTML content cleaning",
      "Authentication required for admin operations"
    ],
    "compliance": [
      "GDPR data handling",
      "Content audit trails",
      "Secure file uploads",
      "No sensitive data exposure"
    ]
  },
  "monitoring": {
    "health_endpoint": "/health",
    "metrics": [
      "Request count and latency",
      "Error rates by endpoint",
      "Memory and CPU usage",
      "Database connection health",
      "Storage operation metrics"
    ],
    "logging": [
      "Structured JSON logs",
      "Request/response logging",
      "Error stack traces",
      "Performance metrics"
    ]
  }
}
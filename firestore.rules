rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - own data + authenticated read for admin functions
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User settings - own data + authenticated read for admin functions
    match /userSettings/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ⭐ SUBSCRIPTIONS - Allow authenticated users to read/write (admin logic in app)
    match /subscriptions/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 🆕 USAGE TRACKING - Daily conversion tracking
    // Document ID format: {userId}_{date} (e.g., "user123_2025-01-15")
    match /usage/{usageDocId} {
      allow read: if request.auth != null &&
        usageDocId.split('_')[0] == request.auth.uid;
      allow write: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        usageDocId.split('_')[0] == request.auth.uid;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId &&
        usageDocId.split('_')[0] == request.auth.uid;
    }

    // Admins collection - readable by authenticated users for admin verification
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Admin actions and logs - authenticated users (real admin check in app)
    match /adminActions/{actionId} {
      allow read, write: if request.auth != null;
    }

    match /adminLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Notifications - authenticated users can manage (admin logic in app)
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }

    // Recipes - authenticated users
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Meal plans - authenticated users
    match /mealPlans/{planId} {
      allow read, write: if request.auth != null;
    }

    // User profiles - authenticated users
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null;
    }

    // System config - authenticated users (admin logic in app)
    match /systemConfig/{document} {
      allow read, write: if request.auth != null;
    }

    // Backups - authenticated users
    match /backups/{backupId} {
      allow read, write: if request.auth != null;
    }

    // 📝 BLOG POSTS - Authenticated users can read/write (admin logic in app)
    match /blog_posts/{postId} {
      // Anyone authenticated can read all posts (published/draft filtering in app)
      allow read: if request.auth != null;
      // Authenticated users can write (admin check in app logic)
      allow write: if request.auth != null;
    }

    // 📂 BLOG CATEGORIES - Authenticated users can read/write (admin logic in app)
    match /blog_categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
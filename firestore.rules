rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - own data + authenticated read for admin functions, admins can manage all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // User settings - own data + authenticated read for admin functions
    match /userSettings/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ⭐ SUBSCRIPTIONS - Users can read/write own data, admins can manage all
    match /subscriptions/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    // 🆕 USAGE TRACKING - Daily conversion tracking
    // Document ID format: {userId}_{date} (e.g., "user123_2025-01-15")
    match /usage/{usageDocId} {
      allow read: if request.auth != null &&
        usageDocId.split('_')[0] == request.auth.uid;
      allow write: if request.auth != null &&
        request.auth.uid == resource.data.userId &&
        usageDocId.split('_')[0] == request.auth.uid;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId &&
        usageDocId.split('_')[0] == request.auth.uid;
    }

    // Admins collection - readable for verification, only admins can manage
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin actions and logs - only admins can access
    match /adminActions/{actionId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /adminLogs/{logId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Notifications - read by all, only admins can manage
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Recipes - users can manage own recipes, admins can manage all
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.ownerUid ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.ownerUid;
    }

    // Meal plans - users can manage own plans, admins can manage all
    match /mealPlans/{planId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // User profiles - users can manage own profile, admins can read all
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // System config - only admins can access
    match /systemConfig/{document} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Backups - users can manage own backups, admins can manage all
    match /backups/{backupId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // 📝 BLOG POSTS - Public read for published posts, admins can manage all
    match /blog_posts/{postId} {
      // Anyone can read published posts (public blog access)
      // Authenticated users can read all posts including drafts (for admin preview)
      allow read: if resource.data.status == 'published' || request.auth != null;
      // Only admins can write blog posts
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 📂 BLOG CATEGORIES - Anyone can read, only admins can manage
    match /blog_categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
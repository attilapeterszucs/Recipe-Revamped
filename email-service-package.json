{
  "name": "reciperevamped-email-service",
  "version": "1.0.0",
  "description": "Email service for Recipe Revamped - Contact form and marketing emails",
  "main": "index.js",
  "scripts": {
    "start": "functions-framework --target=emailService --port=8080",
    "deploy": "gcloud functions deploy emailService --runtime nodejs20 --trigger-http --allow-unauthenticated --set-env-vars NODE_ENV=production,SMTP_HOST=smtp.gmail.com,SMTP_PORT=587,SMTP_USER=noreply@reciperevamped.com,SMTP_PASS=zrjnzhigyitswwlw,CONTACT_EMAIL=info@reciperevamped.com",
    "deploy-with-auth": "gcloud functions deploy emailService --runtime nodejs20 --trigger-http --set-env-vars NODE_ENV=production",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.3.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.8.0",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-google": "^0.14.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": "20"
  },
  "keywords": [
    "email",
    "smtp",
    "contact-form",
    "marketing",
    "firebase",
    "google-cloud",
    "nodejs"
  ],
  "author": "Recipe Revamped Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reciperevamped/email-service.git"
  },
  "bugs": {
    "url": "https://github.com/reciperevamped/email-service/issues"
  },
  "homepage": "https://reciperevamped.com"
}
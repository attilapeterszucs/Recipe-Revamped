# Recipe Revamp Environment Variables (Client-only, public values)
# 🔒 SECURITY: OpenAI API key is stored securely in Firebase Functions (never here!)
# 🚫 DO NOT put OpenAI API key in this file - it would be exposed to users!
VITE_APP_NAME=RecipeRevamp
VITE_ALLOWED_FILTERS=Vegan,Gluten-Free,Low-Carb,Keto,Paleo,Dairy-Free,Nut-Free,Sugar-Free,Vegetarian,Whole30,High-Protein,Low-Sodium,Diabetic-Friendly,Heart-Healthy,Mediterranean,Raw-Food
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Stripe Integration (Client-side safe URLs)
VITE_STRIPE_WEBHOOK_URL=https://stripe-webhook-428797186446.us-central1.run.app

# Google reCAPTCHA (Client-side site keys)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-enterprise-site-key
VITE_RECAPTCHA_V2_NOTAROBOT_KEY=your-recaptcha-v2-site-key

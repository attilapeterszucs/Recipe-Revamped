rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures - users can upload/update their own profile pictures
    match /profiles/{filename} {
      allow read: if true; // Profile pictures are public
      allow write: if request.auth != null &&
                   // Check if filename starts with "profile_{userId}_"
                   filename.matches('profile_' + request.auth.uid + '_.*') &&
                   // Validate file size (5MB limit)
                   request.resource.size < 5 * 1024 * 1024 &&
                   // Validate file type
                   request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
      allow delete: if request.auth != null &&
                    filename.matches('profile_' + request.auth.uid + '_.*');
    }

    // Recipe images - users can upload their own recipe images
    match /recipes/{userId}/{filename} {
      allow read: if true; // Recipe images are public
      allow write: if request.auth != null &&
                   request.auth.uid == userId &&
                   // Validate file size (10MB limit for recipe images)
                   request.resource.size < 10 * 1024 * 1024 &&
                   // Validate file type
                   request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Blog images - allow authenticated users to upload blog images
    match /blog-images/{filename} {
      allow read: if true; // Blog images are public
      allow write: if request.auth != null &&
                   // Validate file size (10MB limit for blog images)
                   request.resource.size < 10 * 1024 * 1024 &&
                   // Validate file type
                   request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
      allow delete: if request.auth != null;
    }

    // Default recipe images from external APIs - public read access
    match /default-recipe-images/{filename} {
      allow read: if true;
      // Only allow writes from Firebase Functions or admins
      allow write: if false; // This will be handled server-side
    }
  }
}